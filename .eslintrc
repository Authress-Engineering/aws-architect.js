{
  "env": {
    "es6": true,
    "node": true
  },
  "extends": [
    "@authress/eslint-config"
  ],
  "rules": {
    "arrow-parens": ["error", "as-needed"],
    "indent": ["error", 2, { "SwitchCase": 1, "MemberExpression": 0 }],
    "node/no-unsupported-features/es-syntax": ["off"],
    "no-throw-literal": "off",
    "spaced-comment": "off",
    "no-continue": "off",
    "require-atomic-updates": "off"
  },
  "overrides": [
    {
      "files": ["tests/**/*.js"],
      "globals": {
        "describe": "readonly",
        "it": "readonly",
        "expect": "readonly",
        "beforeEach": "readonly",
        "afterEach": "readonly",
        "beforeAll": "readonly",
        "afterAll": "readonly",
        "vi": "readonly"
      }
    }
  ]
}
